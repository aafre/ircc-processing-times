---
interface Props {
  date: string;
}

const { date } = Astro.props;
---

<div class="last-updated">
  <span class="last-updated__dot"></span>
  <span class="mono">Latest official IRCC data ({date})</span>
  <span class="last-updated__sep">·</span>
  <span class="last-updated__auto">Updated daily</span>
</div>

<style>
  .last-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .last-updated__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-fast);
    box-shadow: 0 0 8px var(--status-fast);
    flex-shrink: 0;
  }

  .last-updated__sep {
    color: var(--text-muted);
    opacity: 0.4;
  }

  .last-updated__auto {
    color: var(--accent-secondary);
    font-size: 0.75rem;
    font-weight: 500;
  }
</style>
